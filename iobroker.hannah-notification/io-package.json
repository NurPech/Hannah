{
  "common": {
    "name": "hannah-notification",
    "version": "0.1.0",
    "title": "Hannah Notification Provider",
    "icon": "hannah-notification.png",
    "desc": "Leitet Notifications vom Notification Manager per MQTT an Hannah weiter",
    "authors": ["Leonie"],
    "keywords": ["hannah", "notification", "tts", "mqtt"],
    "license": "MIT",
    "type": "messaging",
    "main": "main.js",
    "enabled": true,
    "loglevel": "info",
    "mode": "daemon",
    "platform": "Javascript/Node.js",
    "supportedMessages": {
      "notifications": {
        "enabled": true
      }
    }
  },
  "native": {
    "mqtt_broker": "192.168.8.1",
    "mqtt_port": 1883,
    "mqtt_user": "mqtt",
    "mqtt_pass": "mqttmqtt",
    "hannah_topic": "hannah/notification"
  },
  "instanceObjects": [
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "MQTT verbunden",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
