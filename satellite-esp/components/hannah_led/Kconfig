menu "Hannah LED"

    config HANNAH_LED_GPIO
        int "WS2812B Data GPIO"
        default 48
        help
            GPIO für den WS2812B-LED-Ring (RMT-Peripheral).
            GPIO 48 ist auf dem ESP32-S3-DevKitC-1 frei verfügbar.

    config HANNAH_LED_COUNT
        int "Anzahl LEDs im Ring"
        default 12
        range 1 64

endmenu
